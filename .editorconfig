root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.sh]
indent_style = tab
indent_size = 4

[PKGBUILD]
indent_style = tab
indent_size = 4

[*.py]
indent_size = 4

[{go.mod,go.sum,*.go}]
indent_style = tab

[*.rs]
indent_size = 4

[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets}]
indent_size = 2

[*.{tf,tfvars}]
indent_size = 2
