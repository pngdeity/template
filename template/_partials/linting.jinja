{% if has_python %}
```bash
uv run ruff check . && uv run ruff format --check .
uv run mypy src/
```
{% endif %}
{% if has_node %}
```bash
deno fmt --check && deno lint
```
{% endif %}
{% if has_go %}
```bash
golangci-lint run && gosec ./... && govulncheck ./...
```
go install github.com/securego/gosec/v2/cmd/gosec@latest && go install golang.org/x/vuln/cmd/govulncheck@latest
{% endif %}
{% if has_rust %}
```bash
cargo fmt --check && cargo clippy -- -D warnings
```
{% endif %}
{% if has_dotnet %}
```bash
dotnet format --verify-no-changes
dotnet build --no-restore
```
{% endif %}
{% if has_tofu %}
```bash
tofu fmt -check -recursive
tflint --recursive
terraform-docs markdown table --output-file README.md --output-mode inject .
```
{% endif %}
{% if include_shell_tooling %}
```bash
shellcheck **/*.sh
shfmt -d .
```
{% endif %}
