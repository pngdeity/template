```yaml
# Example Taskfile.yml tasks for Go projects
# See: https://taskfile.dev

tasks:
  default:
    desc: Lint, test, and build
    cmds:
      - task: lint
      - task: test
      - task: build

  lint:
    desc: Run golangci-lint
    cmds:
      - golangci-lint run

  test:
    desc: Run tests with race detector
    cmds:
      - go test -race -shuffle=on -count=1 ./...

  test:cover:
    desc: Run tests with coverage
    cmds:
      - go test -race -coverprofile=coverage.out ./...

  test:bench:
    desc: Run benchmarks
    cmds:
      - go test -bench=. -benchmem ./...

  vuln:
    desc: Check for known vulnerabilities
    cmds:
      - govulncheck ./...

  build:
    desc: Build binaries
    cmds:
      - CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o bin/ ./cmd/...

  tidy:
    desc: Tidy module dependencies
    cmds:
      - go mod tidy

  clean:
    desc: Remove build artifacts
    cmds:
      - rm -rf bin/ dist/
```
