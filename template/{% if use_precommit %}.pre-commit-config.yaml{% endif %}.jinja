repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v6.0.0
    hooks:
      - id: trailing-whitespace
        args: [--markdown-linebreak-ext=md]
      - id: end-of-file-fixer
      - id: check-yaml
        args: [--allow-multiple-documents]
      - id: check-json
      - id: check-merge-conflict
      - id: check-added-large-files
        args: [--maxkb=500]
{% if 'python' in languages %}
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.9.0
    hooks:
      - id: ruff
        args: [--fix]
      - id: ruff-format
{% endif %}
{% if has_node %}
  - repo: local
    hooks:
      - id: deno-fmt
        name: deno fmt
        entry: deno fmt --check
        language: system
        types_or: [javascript, jsx, typescript, tsx, json, markdown, yaml]
        pass_filenames: false
      - id: deno-lint
        name: deno lint
        entry: deno lint
        language: system
        types_or: [javascript, jsx, typescript, tsx]
        pass_filenames: false
{% endif %}
{% if 'go' in languages %}
  - repo: https://github.com/dnephin/pre-commit-golang
    rev: v0.5.1
    hooks:
      - id: go-fmt
      - id: go-vet
      - id: golangci-lint
        args: [--fast]
{% endif %}
{% if 'rust' in languages %}
  - repo: local
    hooks:
      - id: cargo-fmt
        name: cargo fmt
        entry: cargo fmt --check
        language: system
        types: [rust]
        pass_filenames: false
      - id: cargo-clippy
        name: cargo clippy
        entry: cargo clippy -- -D warnings
        language: system
        types: [rust]
        pass_filenames: false
{% endif %}
{% if 'dotnet' in languages %}
  - repo: local
    hooks:
      - id: dotnet-format
        name: dotnet format
        entry: dotnet format style --verify-no-changes
        language: system
        types: [csharp]
        pass_filenames: false
{% endif %}
{% if 'tofu' in languages %}
  - repo: https://github.com/antonbabenko/pre-commit-terraform
    rev: v1.98.0
    hooks:
      - id: tofu_fmt
      - id: tofu_tflint
{% endif %}
{% if include_shell_tooling %}
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.10.0.1
    hooks:
      - id: shellcheck
{% endif %}
{% if use_commitlint %}
  - repo: https://github.com/commitizen-tools/commitizen
    rev: v4.4.0
    hooks:
      - id: commitizen
        stages: [commit-msg]
{% endif %}
