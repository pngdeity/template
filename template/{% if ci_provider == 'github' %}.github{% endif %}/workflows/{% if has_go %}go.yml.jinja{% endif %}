name: Go

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  GO_VERSION: "{{ go_directive }}"

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          {% raw %}go-version: ${{ env.GO_VERSION }}{% endraw %}
          cache: true
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest

  test:
    runs-on: ubuntu-latest
    needs: lint
    strategy:
      matrix:
        go-version: ["{{ go_directive }}", "{{ go_prior1 }}", "{{ go_prior2 }}"]
      fail-fast: false
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          {% raw %}go-version: ${{ matrix.go-version }}{% endraw %}
          cache: true
      - run: go test -race -shuffle=on -count=1 -coverprofile=coverage.out ./...
      - uses: codecov/codecov-action@v5
        with:
          files: coverage.out
          fail_ci_if_error: false

  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          {% raw %}go-version: ${{ env.GO_VERSION }}{% endraw %}
      - uses: golang/govulncheck-action@v1
      - uses: securego/gosec@v2
        with:
          args: -severity medium -confidence medium ./...

  tidy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          {% raw %}go-version: ${{ env.GO_VERSION }}{% endraw %}
      - run: go mod tidy
      - run: git diff --exit-code

  build:
    runs-on: ubuntu-latest
    needs: [test, security, tidy]
    if: startsWith(github.ref, 'refs/tags/')
    strategy:
      matrix:
        goos: [linux, darwin, windows]
        goarch: [amd64, arm64]
      fail-fast: false
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          {% raw %}go-version: ${{ env.GO_VERSION }}{% endraw %}
      - run: |
          {% raw %}CGO_ENABLED=0 GOOS=${{ matrix.goos }} GOARCH=${{ matrix.goarch }} \{% endraw %}
            go build -trimpath -ldflags="-s -w" -o dist/ {% if go_scaffolding == 'application' %}./cmd/...{% else %}.{% endif %}
      - uses: actions/upload-artifact@v4
        with:
          {% raw %}name: ${{ matrix.goos }}-${{ matrix.goarch }}{% endraw %}
          path: dist/
