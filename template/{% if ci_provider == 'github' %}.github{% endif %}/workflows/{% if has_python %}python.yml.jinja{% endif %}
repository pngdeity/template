name: Python

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
      - run: uv sync
      - run: uv run ruff check . && uv run ruff format --check .
{% if python_scaffolding == 'application' %}
      - run: uv run mypy src/
{% endif %}

  test:
    runs-on: ubuntu-latest
    needs: lint
    strategy:
      matrix:
        python-version: ["{{ python_version }}", "3.{{ (python_version.split('.')[1] | int + 1) }}", "3.{{ (python_version.split('.')[1] | int + 2) }}"]
      fail-fast: false
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
        with:
          {% raw %}python-version: ${{ matrix.python-version }}{% endraw %}
      - run: uv sync
      - run: uv run pytest
